# Required: the shared password gating the whole dashboard.
# Set this in the Vercel project Settings -> Environment Variables.
DASHBOARD_PASSWORD=

# Upstash Redis variables — auto-set by the "Upstash for Redis"
# Marketplace integration. The integration keeps the KV_* names for
# backward compat with the deprecated @vercel/kv package:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
# REDIS_URL=
