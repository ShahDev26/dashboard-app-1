# =============================================================================
# MEL QA Automation — environment configuration template.
# Copy to .env (gitignored). Override per-run with TEST_ENV=dev|stage|prod.
#
# Each env block uses the prefix DEV_, STAGE_, or PROD_.
# Each role has _EMAIL, _MOBILE, _PASS (use whichever your spec needs).
# Supported roles: ADMIN, STATEHEAD, GSCO, FIRSTLOGIN, BLOCKED, QAADMIN.
# =============================================================================

TEST_ENV=dev

# -- Dev (local) --------------------------------------------------------------
DEV_BASE_URL=http://localhost:5173
DEV_LOGIN_PATH=/login
DEV_API_URL=http://localhost:3000

DEV_ADMIN_EMAIL=
DEV_ADMIN_MOBILE=
DEV_ADMIN_PASS=
DEV_STATEHEAD_EMAIL=
DEV_STATEHEAD_MOBILE=
DEV_STATEHEAD_PASS=
DEV_GSCO_EMAIL=
DEV_GSCO_MOBILE=
DEV_GSCO_PASS=
DEV_FIRSTLOGIN_EMAIL=
DEV_FIRSTLOGIN_MOBILE=
DEV_FIRSTLOGIN_PASS=
DEV_BLOCKED_EMAIL=
DEV_BLOCKED_MOBILE=
DEV_BLOCKED_PASS=
DEV_QAADMIN_EMAIL=
DEV_QAADMIN_MOBILE=
DEV_QAADMIN_PASS=

# -- Stage --------------------------------------------------------------------
STAGE_BASE_URL=
STAGE_LOGIN_PATH=/login
STAGE_API_URL=
STAGE_ADMIN_EMAIL=
STAGE_ADMIN_MOBILE=
STAGE_ADMIN_PASS=
STAGE_STATEHEAD_EMAIL=
STAGE_STATEHEAD_MOBILE=
STAGE_STATEHEAD_PASS=
STAGE_GSCO_EMAIL=
STAGE_GSCO_MOBILE=
STAGE_GSCO_PASS=
STAGE_FIRSTLOGIN_EMAIL=
STAGE_FIRSTLOGIN_MOBILE=
STAGE_FIRSTLOGIN_PASS=
STAGE_BLOCKED_EMAIL=
STAGE_BLOCKED_MOBILE=
STAGE_BLOCKED_PASS=
STAGE_QAADMIN_EMAIL=
STAGE_QAADMIN_MOBILE=
STAGE_QAADMIN_PASS=

# -- Production ---------------------------------------------------------------
PROD_BASE_URL=
PROD_LOGIN_PATH=/login
PROD_API_URL=
PROD_ADMIN_EMAIL=
PROD_ADMIN_MOBILE=
PROD_ADMIN_PASS=
PROD_STATEHEAD_EMAIL=
PROD_STATEHEAD_MOBILE=
PROD_STATEHEAD_PASS=
PROD_GSCO_EMAIL=
PROD_GSCO_MOBILE=
PROD_GSCO_PASS=
PROD_FIRSTLOGIN_EMAIL=
PROD_FIRSTLOGIN_MOBILE=
PROD_FIRSTLOGIN_PASS=
PROD_BLOCKED_EMAIL=
PROD_BLOCKED_MOBILE=
PROD_BLOCKED_PASS=
PROD_QAADMIN_EMAIL=
PROD_QAADMIN_MOBILE=
PROD_QAADMIN_PASS=

# -- MEL Test Dashboard (testcase source — same for every env) ----------------
DASHBOARD_URL=https://dashboard-app-sigma-gilt.vercel.app
DASHBOARD_PASSWORD=

# -- Runtime knobs ------------------------------------------------------------
HEADLESS=true
SCREENSHOT_ON_FAILURE=only-on-failure
VIDEO=retain-on-failure
TRACE=retain-on-failure
DEFAULT_TIMEOUT_MS=30000
